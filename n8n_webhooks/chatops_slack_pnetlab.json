{
  "name": "PNetLab Slack ChatOps",
  "nodes": [
    {
      "id": "9a9a9610-febc-45de-8145-3446af249fa7",
      "name": "Slack Events",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        300
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "slack-chatops",
        "responseMode": "responseNode"
      },
      "webhookId": "ea08e78e-d135-48da-b232-65ee9c3e2337"
    },
    {
      "id": "e350c2b4-8dee-4e8b-bf4b-4944a7c33e4c",
      "name": "Is URL Verification?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $json.body.type }}",
              "rightValue": "url_verification",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "3d41e89c-7590-490d-be54-d7cc798cf13b",
      "name": "Respond Challenge",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        480,
        180
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({challenge: $json.body.challenge}) }}"
      }
    },
    {
      "id": "8d7a7984-8107-47cf-981f-4776257f1709",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        480,
        420
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ok: true}) }}"
      }
    },
    {
      "id": "6e219284-758c-4a1a-8842-6aff679467a6",
      "name": "Parse Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        420
      ],
      "parameters": {
        "jsCode": "// Slack event -> {command, phase, channel, user}\nconst body = $input.first().json.body ?? {};\nconst ev = body.event ?? {};\n// ignore bot echoes and message edits, or the bot loops on its own replies\nif (!ev.type || ev.bot_id || ev.subtype) { return []; }\nconst text = (ev.text || '').replace(/<@[^>]+>/g, '').trim().toLowerCase();\nlet command = 'unknown', phase = null;\nif (/^help\\b/.test(text)) command = 'help';\nelse if (/^status\\b/.test(text)) command = 'status';\nelse if (/^run\\s+all\\b/.test(text)) command = 'run_all';\nelse { const m = text.match(/^(?:run\\s+)?phase\\s*([1-5])\\b/); if (m) { command = 'phase'; phase = m[1]; } }\nreturn [{ json: { command, phase, channel: ev.channel, user: ev.user, raw: text } }];\n"
      }
    },
    {
      "id": "187d4128-9dfb-4a41-b39f-2fe9baf377bf",
      "name": "Route Command",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        960,
        420
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "help",
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "help",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true
            },
            {
              "outputKey": "status",
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "status",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true
            },
            {
              "outputKey": "run",
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "combinator": "or",
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "run_all",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  },
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "phase",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      }
    },
    {
      "id": "7e4087f4-d627-45fd-a157-375c11c1e958",
      "name": "Post Help",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [
        1220,
        120
      ],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $('Parse Command').first().json.channel }}",
          "mode": "id"
        },
        "text": "=*PNetLab ChatOps \u2014 Available Commands*\n\u2022 `phase 1` \u2014 Core Switching (VLANs, STP, trunks)\n\u2022 `phase 2` \u2014 Routing Underlay (OSPF area 0)\n\u2022 `phase 3` \u2014 Overlay VXLAN (BGP EVPN, NX-OS)\n\u2022 `phase 4` \u2014 Edge WAN (NAT/PAT, ACL)\n\u2022 `phase 5` \u2014 Client Onboard (DHCP, E2E ping)\n\u2022 `run all` \u2014 full site.yml, phases 1-5 with gates\n\u2022 `status` \u2014 devbox-104 health + PNetLab reachability\n\u2022 `help` \u2014 this message",
        "otherOptions": {}
      },
      "credentials": {
        "slackApi": {
          "id": "REPLACE_AFTER_IMPORT",
          "name": "Slack Bot (ops-agent)"
        }
      }
    },
    {
      "id": "359ed055-e27a-42e6-bd09-52374628d6d8",
      "name": "Devbox Status",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [
        1220,
        300
      ],
      "parameters": {
        "authentication": "privateKey",
        "command": "uptime && echo \"---\" && docker ps --format \"table {{.Names}}\\t{{.Status}}\" && echo \"---\" && ip route show 172.100.1.0/24 && (ping -c 1 -W 2 172.100.1.101 >/dev/null 2>&1 && echo \"PNetLab mgmt net: reachable\" || echo \"PNetLab mgmt net: UNREACHABLE\")",
        "cwd": "/opt/pnetlab-playbooks"
      },
      "credentials": {
        "sshPrivateKey": {
          "id": "REPLACE_AFTER_IMPORT",
          "name": "devbox-104 SSH"
        }
      }
    },
    {
      "id": "ea4d5b42-e3ec-4745-bf84-81ca9d0f913c",
